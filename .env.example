# .env.example — environment variable template for BanyanBoard (committed).
#
# Copy this file to `.env` (git-ignored) and adjust as needed. The defaults below
# work out of the box with `docker compose up` for local development.

# ── Application (Express API) ────────────────────────────────────────────────
# HTTP listen port.
PORT=3000
# Deployment environment: development | production | test.
NODE_ENV=development
# Log verbosity: trace | debug | info | warn | error | fatal.
LOG_LEVEL=info

# PostgreSQL connection DSN consumed by the app (src/config/env.ts -> config.databaseUrl).
# The credentials/host/db below match the POSTGRES_* compose defaults. The app runs on
# the host and reaches the container via the published 5432 port, hence `localhost`.
DATABASE_URL=postgres://banyan:banyan@localhost:5432/banyanboard

# ── PostgreSQL container (docker-compose.yml) ────────────────────────────────
# These configure the `postgres` service. Keep them in sync with DATABASE_URL above.
POSTGRES_USER=banyan
POSTGRES_PASSWORD=banyan
POSTGRES_DB=banyanboard
